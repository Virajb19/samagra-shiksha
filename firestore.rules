rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──

    function isAuth() {
      return request.auth != null;
    }

    function getRole() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return isAuth() && getRole() in ['ADMIN', 'SUPER_ADMIN'];
    }

    function isHeadmaster() {
      return isAuth() && getRole() == 'HEADMASTER';
    }

    // ── Users ──
    match /users/{userId} {
      allow read: if isAuth();
      // Allow self-create and self-update: newly registered users have no role claim yet
      allow create: if isAuth() && (isAdmin() || request.auth.uid == userId);
      // Admins: full update; Self (by Auth UID): full update;
      // Any authenticated user: personal details only (covers seeded users whose doc ID ≠ Auth UID);
      // Headmasters: only is_active + updated_at
      allow update: if isAdmin()
                    || request.auth.uid == userId
                    || (isAuth() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'phone', 'gender', 'profile_image_url', 'updated_at']))
                    || (isAuth() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['is_active', 'updated_at']));
      allow delete: if isAdmin();
    }

    // ── Faculties ──
    match /faculties/{facultyId} {
      allow read: if isAuth();
      // Allow teachers/headmasters to create/update their own faculty profile
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }

    // ── Schools ──
    match /schools/{schoolId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // ── Districts ──
    match /districts/{districtId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Teaching Assignments ──
    match /teaching_assignments/{assignmentId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Subjects ──
    match /subjects/{subjectId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Audit Logs (append-only, no edits/deletes) ──
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // ── Helpdesk Tickets ──
    match /helpdesk_tickets/{ticketId} {
       allow read: if isAdmin() || (isAuth() && resource.data.user_id == request.auth.uid);
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Notices ──
    match /notices/{noticeId} {
      allow read: if isAuth();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Notice Recipients ──
    match /notice_recipients/{recipientId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin()
        || (isAuth()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reject_reason', 'responded_at']));
      allow delete: if isAdmin();
    }

    // ── Circulars ──
    match /circulars/{circularId} {
      // Admin CMS uses list queries with filters/orderBy + pagination (startAfter)
      allow get, list: if isAuth();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Events ──
    match /events/{eventId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // ── Circular Schools (join table) ──
    match /circular_schools/{csId} {
      allow get, list: if isAuth();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── User Stars ──
    match /user_stars/{starId} {
      allow read: if isAuth();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Project Schools (Project Management) ──
    match /project_schools/{schoolId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // ── Projects (Project Management) ──
    match /projects/{projectId} {
      allow read: if isAuth();
      allow create, delete: if isAdmin();
      // Admins: full update; any authenticated user: only progress, photos, status, updated_at
      allow update: if isAdmin()
                    || (isAuth()
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['progress', 'photos', 'status', 'updated_at']));
    }

    // ── Project Updates (submitted by Junior Engineers) ──
    match /project_updates/{updateId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // ── Activity Forms ──
    match /activity_forms/{formId} {
      allow read: if isAuth();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── ICT Form Data (submitted forms) ──
    match /ict_form_data/{docId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }

    // ── Library Form Data (submitted forms) ──
    match /library_form_data/{docId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }

    // ── Science Lab Form Data (submitted forms) ──
    match /science_lab_form_data/{docId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }

    // ── Self Defense Form Data (submitted forms) ──
    match /self_defense_form_data/{docId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }

    // ── KGBV Form Data (submitted by KGBV wardens) ──
    match /kgbv_form_data/{docId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }

    // ── NSCBAV Form Data (submitted by NSCBAV wardens) ──
    match /nscbav_form_data/{docId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }

    // ── Vocational Education Form Data (submitted by teachers) ──
    match /vocational_education_form_data/{docId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }

    // ── IE School Visit Data (submitted by IE Resource Persons) ──
    match /ie_school_visit_data/{docId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }

    // ── IE Home Visit Data (submitted by IE Resource Persons) ──
    match /ie_home_visit_data/{docId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }

    // ── Audit Logs ──
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // ── Missing Form Submissions (computed by Cloud Function) ──
    match /missing_form_submissions/{docId} {
      allow read: if isAdmin();
      allow write: if false; // Only written by Cloud Function via admin SDK
    }

    // ── Deny everything else by default ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
